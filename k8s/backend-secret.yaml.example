apiVersion: v1
kind: Secret
metadata:
  name: backend-secret
  namespace: super-meal
type: Opaque
stringData:
  MONGODB_URL: "mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"
  PORT: "5000"
  CORS_ORIGIN: "http://localhost"   # update to your domain in production
