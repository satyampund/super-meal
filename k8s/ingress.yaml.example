apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: super-meal-ingress
  namespace: super-meal
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
spec:
  ingressClassName: nginx
  rules:
    - host: super-meal.local   # replace with your actual domain
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: frontend
                port:
                  number: 80
